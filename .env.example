# MongoDB (Required for User and Assessment data)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/

# Clerk Auth (Required for Login)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Razorpay (Optional - for Checkout)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Brevo Email (Optional)
BREVO_API_KEY=xkeysib-...

# Telegram Bot (Optional)
TELEGRAM_BOT_TOKEN=1234567890:AA...

# Base URL (for callbacks/redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local Open-Source ML (Ollama) - Required for AI Interview Feature
OLLAMA_BASE_URL=http://127.0.0.1:11434
